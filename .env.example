# .env.local

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── n8n Webhooks ─────────────────────────────────────────────────────────────
N8N_WEBHOOK_EVIDENCE_UPLOADED=https://your-n8n.cloud/webhook/evidence-uploaded
N8N_WEBHOOK_CASE_CREATED=https://your-n8n.cloud/webhook/case-created
N8N_WEBHOOK_EMERGENCY_ALERT=https://your-n8n.cloud/webhook/emergency-alert
N8N_WEBHOOK_REPORT_GENERATED=https://your-n8n.cloud/webhook/report-generated

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.co.ke
NEXT_PUBLIC_APP_ENV=production

# ── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
